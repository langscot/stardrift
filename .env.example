# ── Discord ──────────────────────────────────────────────────────────────────
# Get these from https://discord.com/developers/applications
DISCORD_TOKEN=your-bot-token-here
DISCORD_CLIENT_ID=your-client-id-here

# Optional: set to your server ID for instant command registration during dev
# Leave blank for global commands (takes up to 1 hour to propagate)
DISCORD_DEV_GUILD_ID=

# ── Database ──────────────────────────────────────────────────────────────────
# When running via Docker Compose, leave this as-is.
# When running locally (npm run dev), change host to localhost.
DATABASE_URL=postgresql://stellar:stellar_password@localhost:5432/stardrift

# ── Redis ─────────────────────────────────────────────────────────────────────
# When running via Docker Compose, leave this as-is.
REDIS_URL=redis://localhost:6379

# ── Game Tuning ───────────────────────────────────────────────────────────────
MINING_COOLDOWN_SECONDS=30
FUEL_PER_LY=1
SECONDS_PER_LY=60
TRAVEL_CHECK_INTERVAL_MS=30000
PRICE_DECAY_RATE=0.95

# ── AI Q&A (optional) ──────────────────────────────────────────────────────
# API key for Vercel AI Gateway. If not set, the @Aria Q&A feature is disabled.
# Get one from https://vercel.com → Settings → AI Gateway
AI_GATEWAY_API_KEY=
# Model to use via the gateway (default: google/gemini-2.0-flash-lite)
AI_MODEL=google/gemini-2.0-flash-lite

# ── Content Moderation (optional) ─────────────────────────────────────────────
# OpenAI API key for pre-moderation via /v1/moderations before hitting Aria.
# If not set, moderation is skipped entirely.
OPENAI_API_KEY=

# ── Admin system ───────────────────────────────────────────────────────────────
# Comma-separated Discord user IDs granted admin access.
# Admins get: no Aria rate limit, access to /admin commands.
# Elevated actions (ban/unban) also require /admin activate with a TOTP code.
ADMIN_USER_IDS=